# Askesis self-host config template. Copy to .env and fill in REAL values.
#   cp .env.example .env
# .env is gitignored — never put real secrets/hosts/emails in THIS file.
# Consumed by docker-compose.yml and passed into the app container.

# ── Where to publish the app ───────────────────────────────────────────────
# Host IP to bind (e.g. your Tailscale IP, or 0.0.0.0 for all interfaces) + port.
BIND_ADDR=127.0.0.1
APP_PORT=8000

# ── Postgres (the bundled db service) ──────────────────────────────────────
# Pick a strong password. Used by the db service and the app's DATABASE_URL.
POSTGRES_PASSWORD=change-me

# ── App secrets ────────────────────────────────────────────────────────────
# Session/JWT signing key.  Generate: openssl rand -hex 32
SECRET_KEY=change-me-openssl-rand-hex-32

# Encrypts Google refresh tokens at rest.
# IMPORTANT: if migrating from Railway, set this to the SAME value used there,
# or every user must re-link Google (and Drive photos won't load until they do).
# New install: openssl rand -hex 32 . Leave blank to fall back to SECRET_KEY.
ENCRYPTION_KEY=

# ── Google OAuth ───────────────────────────────────────────────────────────
# Add your host's redirect URI in the Google Cloud console:
#   https://<machine>.<tailnet>.ts.net:<port>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Who is allowed to sign in (JSON array of emails).
ALLOWED_EMAILS=["you@example.com"]

# ── Web / CORS ─────────────────────────────────────────────────────────────
# JSON array of allowed origins (your HTTPS host + Capacitor app origins).
CORS_ORIGINS=["https://<machine>.<tailnet>.ts.net:<port>","https://localhost","capacitor://localhost"]

# Production mode: true => HTTPS-only cookies (correct behind a TLS proxy).
DEV_MODE=false

# ── Optional ───────────────────────────────────────────────────────────────
TOKEN_EXPIRE_HOURS=720
USDA_API_KEY=

# DATABASE_URL is set by docker-compose to the bundled db service; only set it
# here if you remove that service to use an external Postgres:
# DATABASE_URL=postgresql://user:pass@host:5432/askesis
