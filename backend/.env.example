# Development mode - enables auto-login without OAuth
DEV_MODE=true

DATABASE_URL=sqlite:///./askesis.db
SECRET_KEY=your-secret-key-change-in-production

# CORS origins (JSON array format)
CORS_ORIGINS=["http://localhost:5173"]

# Token expiration in hours (default: 2)
TOKEN_EXPIRE_HOURS=2

# Only needed when DEV_MODE=false
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
ALLOWED_EMAILS=["your@email.com","spouse@email.com"]

# External food databases (optional - Open Food Facts works without a key)
# Get free USDA key at: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=

# ===== PRODUCTION SETTINGS =====
# DEV_MODE=false
# SECRET_KEY=<generate with: openssl rand -hex 32>
# CORS_ORIGINS=["https://yourapp.railway.app"]
# TOKEN_EXPIRE_HOURS=2
