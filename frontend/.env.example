# Frontend build-time configuration.
# Copy to .env.production (or set in CI) for the Capacitor Android build.
# The web build is same-origin and ignores this — leave VITE_API_BASE empty
# when running `npm run dev`; the Vite proxy handles /api and /auth.

# Absolute backend URL the Capacitor app should call. Required for the
# native build. The default below is the production Railway deploy.
VITE_API_BASE=https://askesisapp-production.up.railway.app
